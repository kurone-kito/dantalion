{
  "$schema": "https://json.schemastore.org/stryker",
  "packageManager": "pnpm",
  "testRunner": "vitest",
  "plugins": ["@stryker-mutator/vitest-runner"],
  "vitest": {
    "configFile": "vitest.config.mts"
  },
  "reporters": ["progress", "clear-text", "json"],
  "concurrency": 2,
  "mutate": [
    "src/**/*.ts",
    "!src/**/*.spec.ts",
    "!src/tests/**",
    "!src/records/**",
    "!src/index.ts",
    "!src/types/**"
  ],
  "coverageAnalysis": "perTest",
  "timeoutMS": 30000
}

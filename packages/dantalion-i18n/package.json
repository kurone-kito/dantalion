{
  "name": "@kurone-kito/dantalion-i18n",
  "version": "1.0.0-alpha.1",
  "description": "Converts results of dantalion into detailed documentation.",
  "keywords": [
    "ba-zi",
    "bazi",
    "birthday",
    "chinese-astrology",
    "four-pillars",
    "i18n",
    "library",
    "self-assessment",
    "ziweidoushu",
    "zodiac"
  ],
  "homepage": "https://github.com/kurone-kito/dantalion#readme",
  "bugs": "https://github.com/kurone-kito/dantalion/issues",
  "license": "MIT",
  "author": "kurone-kito <krone@kit.black> (https://kit.black/)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kurone-kito/dantalion.git",
    "directory": "packages/dantalion-i18n"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf dist *.tsbuildinfo",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test:vitest": "vitest run --coverage",
    "test:ts": "tsc -p tsconfig.test.json --noEmit"
  },
  "dependencies": {
    "@kurone-kito/dantalion-core": "workspace:^",
    "i18next": "^26.0.0",
    "lodash.merge": "^4.6.2"
  },
  "devDependencies": {
    "@types/lodash.merge": "^4.6.9"
  },
  "engines": {
    "node": "^22 || >=24"
  },
  "publishConfig": {
    "access": "public"
  }
}

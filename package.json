{
  "name": "@kurone-kito/dantalion",
  "version": "1.0.0-alpha.0",
  "description": "Calculates the personality from the birthday using Four Pillars of Destiny (Ba-Zi).",
  "keywords": [
    "ba-zi",
    "bazi",
    "birthday",
    "chinese-astrology",
    "console",
    "console-app",
    "four-pillars",
    "library",
    "self-assessment",
    "terminal-app",
    "ziweidoushu",
    "zodiac"
  ],
  "homepage": "https://github.com/kurone-kito/dantalion#readme",
  "bugs": "https://github.com/kurone-kito/dantalion/issues",
  "repository": "github:kurone-kito/dantalion",
  "author": "kurone-kito <krone@kit.black> (https://kit.black/)",
  "license": "MIT",
  "private": true,
  "type": "module",
  "files": [],
  "workspaces": {
    "packages": [
      "./packages/*"
    ]
  },
  "scripts": {
    "build": "pnpm --aggregate-output --if-present --workspace-concurrency=0 -r run build",
    "clean": "pnpm run --no-bail \"/^clean:.+/\"",
    "clean:root": "rimraf -g \"*.tgz\" \"*.tsbuildinfo\" coverage node_modules/.cache",
    "clean:sub": "pnpm --aggregate-output --if-present --parallel --workspace-concurrency=0 -r run clean",
    "dev": "pnpm --if-present --parallel --stream --workspace-concurrency=Infinity -r run dev",
    "is:prerelease": "is-prerelease $(npm pkg get version) pre",
    "is:release": "is-prerelease $(npm pkg get version)",
    "lint": "pnpm run --stream \"/lint:check:.+/\"",
    "lint:check:biome": "biome check",
    "lint:check:cspell": "cspell lint --show-suggestions .",
    "lint:check:markdown": "markdownlint-cli2 \"**/*.md\"",
    "lint:fix": "pnpm run --stream \"/(lint:fix:.+|lint:check:cspell)/\"",
    "lint:fix:biome": "biome check --write",
    "lint:fix:markdown": "markdownlint-cli2 --fix \"**/*.md\"",
    "prepare": "husky",
    "publish": "pnpm -r publish --no-git-checks",
    "publish:next": "pnpm -r publish --tag next --no-git-checks",
    "test": "pnpm run \"/test:.+/\"",
    "test:e2e": "pnpm run -r test:e2e",
    "test:ts": "pnpm --aggregate-output --workspace-concurrency=0 -r exec tsc -p tsconfig.test.json --noEmit",
    "test:vitest": "NODE_OPTIONS=\"--conditions=browser\" vitest run --coverage",
    "pretest": "pnpm --aggregate-output --if-present --workspace-concurrency=0 -r run build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@cspell/cspell-types": "^9.7.0",
    "@kurone-kito/biome-config": "^0.23.0-alpha.1",
    "@kurone-kito/commitlint-config": "^0.23.0-alpha.1",
    "@kurone-kito/cspell-config": "^0.23.0-alpha.1",
    "@kurone-kito/is-prerelease": "^0.1.0",
    "@kurone-kito/lint-staged-config": "^0.23.0-alpha.1",
    "@kurone-kito/markdownlint-config": "^0.23.0-alpha.1",
    "@vitest/coverage-v8": "^4.1.2",
    "cspell": "^9.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "markdownlint-cli2": "^0.22.0",
    "rimraf": "^6.1.3",
    "typescript": "~6.0.2",
    "vitest": "^4.1.2"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "engines": {
    "node": "^20.18 || ^22 || >=24"
  },
  "publishConfig": {
    "access": "public"
  }
}
